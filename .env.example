# Frontend (safe to expose in the browser bundle — protected by RLS, not secrecy)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Used ONLY by scripts/seed.mjs and scripts/create-admin.mjs (never imported
# by frontend code). Keep secret — this key bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
